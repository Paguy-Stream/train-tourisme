# ═══════════════════════════════════════════════════════════════════════════════
# CALLBACK PRINCIPAL (OPTIMISÉ AVEC EXÉCUTION PARALLÈLE)
# ═══════════════════════════════════════════════════════════════════════════════

@callback(
    Output("cyclability-score-banner", "children"),
    Output("velos-section", "children"),
    Output("mob-stats", "children"),
    Output("mob-map", "center"),
    Output("mob-map", "zoom"),
    Output("mob-layer", "children"),
    Output("stations-layer", "children"),
    Output("heatmap-data-store", "data"),
    Output("mob-legend", "children"),
    Output("intermodal-comparison", "children"),
    Output("typical-routes", "children"),
    Output("trends-chart", "children"),
    Output("trends-status-badge", "children"),
    Output("poi-pagination-controls", "children"),
    Output("selected-ville-store", "data"),
    Input("mob-gare-select", "value"),
    Input("mob-rayon", "value"),
    Input("mob-options", "value"),
    Input("auto-refresh", "n_intervals"),
    State("poi-pagination-store", "data"),
    running=[(Output("velos-section", "children"), skeleton_card(), None)],
    prevent_initial_call=False,
)

def update_mobilite(gare_libelle, rayon_km, options, n_intervals, pagination_state):
    if not gare_libelle:
        raise PreventUpdate
    
    start_time = time.time()
    
    # Récupérer les coordonnées de la gare
    gare_match = df_gares[df_gares["libelle"] == gare_libelle]
    if gare_match.empty:
        gare = df_gares.iloc[0]
    else:
        gare = gare_match.iloc[0]
    
    gare_lat, gare_lon = float(gare["latitude"]), float(gare["longitude"])
    center = [gare_lat, gare_lon]
    zoom = {2: 15, 5: 13, 10: 12}.get(rayon_km, 13)
    
    print(f"\n[mobilite] 📍 Analyse: {gare_libelle} | {rayon_km}km")
    
    # === 1. DONNÉES GBFS ===
    villes_detectees = detecter_villes_gbfs(gare_libelle)
    
    # ✅ CORRECTION : Utiliser le rayon utilisateur comme base, pas un rayon fixe par ville
    # Le rayon pour les vélos doit être cohérent avec le rayon d'analyse global
    
    # Stratégie : 
    # - Rayon utilisateur = 2km → vélos : 2km (pas de réduction)
    # - Rayon utilisateur = 5km → vélos : 5km (pas de réduction)  
    # - Rayon utilisateur = 10km → vélos : 5km max (les vélos sont pour du court trajet)
    
    if rayon_km <= 5:
        radius_velos = rayon_km  # ✅ Même rayon pour cohérence
    else:
        radius_velos = 5.0  # ✅ Plafond à 5km pour les vélos (pertinence)
    
    print(f"[mobilite] 📏 Rayon vélos: {radius_velos}km (basé sur rayon analyse: {rayon_km}km)")
    
    # Première récupération
    stations_by_ville = get_stations_proximite(villes_detectees, gare_lat, gare_lon, radius_velos)
    total_stations = sum(len(s) for s in stations_by_ville.values())
    
    # 🔧 EXPANSION AUTOMATIQUE : Si moins de 5 stations ET rayon < 10km
    expansion_faite = False
    if total_stations < 5 and radius_velos < 10.0:
        ancien_rayon = radius_velos
        
        # Expansion progressive jusqu'à trouver des stations ou atteindre 10km
        for nouveau_rayon in [5.0, 7.0, 10.0]:
            if nouveau_rayon <= ancien_rayon:
                continue
            
            print(f"[mobilite] 🔄 Expansion: {ancien_rayon}km → {nouveau_rayon}km "
                  f"(seulement {total_stations} stations)")
            
            stations_by_ville = get_stations_proximite(villes_detectees, gare_lat, gare_lon, nouveau_rayon)
            total_stations = sum(len(s) for s in stations_by_ville.values())
            radius_velos = nouveau_rayon
            expansion_faite = True
            
            if total_stations >= 5:
                print(f"[mobilite] ✅ Expansion réussie: {total_stations} stations trouvées")
                break
    
    if expansion_faite and total_stations < 5:
        print(f"[mobilite] ⚠️ Expansion max atteinte (10km), mais toujours peu de stations ({total_stations})")
        # Dernier recours : chercher dans toutes les villes disponibles sans filtre distance
        if villes_detectees:
            print(f"[mobilite] 🔄 Tentative sans filtre distance pour {villes_detectees}")
            # Récupérer toutes les stations de la ville sans filtre
            try:
                all_stations = loop_manager.run_async(
                    gbfs_client.get_all_stations(cities=villes_detectees)
                )
                if all_stations:
                    # Prendre les 10 plus proches
                    stations_with_dist = []
                    for s in all_stations:
                        if s.lat and s.lon:
                            dist = compute_distance_km(gare_lat, gare_lon, s.lat, s.lon)
                            stations_with_dist.append((s, dist))
                    
                    stations_with_dist.sort(key=lambda x: x[1])
                    closest = stations_with_dist[:10]
                    
                    # Reconstruire le format attendu
                    stations_by_ville = {}
                    for station, dist in closest:
                        if station.city not in stations_by_ville:
                            stations_by_ville[station.city] = []
                        
                        total_vehicles = (
                            station.num_bikes_available + 
                            station.num_ebikes_available + 
                            station.num_scooters_available
                        )
                        
                        stations_by_ville[station.city].append({
                            "id": station.station_id,
                            "nom": station.name[:40] + "..." if len(station.name) > 40 else station.name,
                            "lat": station.lat,
                            "lon": station.lon,
                            "distance_m": int(dist * 1000),
                            "velos": total_vehicles,
                            "velos_meca": station.num_bikes_available,
                            "velos_elec": station.num_ebikes_available,
                            "scooters": station.num_scooters_available,
                            "places": station.num_docks_available,
                            "capacity": station.capacity,
                            "actif": station.is_renting,
                            "reseau": f"{station.operator}",
                            "type": "free_floating" if station.station_id.startswith("free_") else "station",
                            "occupation": (total_vehicles / station.capacity * 100) if station.capacity > 0 else 0
                        })
                    
                    total_stations = sum(len(s) for s in stations_by_ville.values())
                    print(f"[mobilite] ✅ Fallback réussi: {total_stations} stations (sans filtre)")
            except Exception as e:
                print(f"[mobilite] ❌ Fallback échoué: {e}")
    
    # Section vélos (avec le rayon final pour l'affichage)
    velos_section = build_velo_section_avancee(stations_by_ville, villes_detectees, gare_libelle, radius_velos)
    
    
# === 2. POINTS D'INTÉRÊT AVEC PAGINATION ===
    poi_locaux = filter_poi_by_bbox(df_poi, gare_lat, gare_lon, rayon_km)
    
    if len(poi_locaux) > 0:
        poi_locaux["distance_km"] = poi_locaux.apply(
            lambda r: compute_distance_km(gare_lat, gare_lon, r["latitude"], r["longitude"]),
            axis=1
        )
        poi_locaux = poi_locaux.sort_values("distance_km")
    
    # Pagination
    page = pagination_state.get("page", 0)
    page_size = pagination_state.get("page_size", 20)
    total_poi = len(poi_locaux)
    total_pages = (total_poi + page_size - 1) // page_size
    
    start_idx = page * page_size
    end_idx = start_idx + page_size
    poi_page = poi_locaux.iloc[start_idx:end_idx] if len(poi_locaux) > 0 else poi_locaux
    
    pagination_controls = html.Div([
        html.Button(
            "◀ Précédent",
            id="poi-prev",
            disabled=(page <= 0),
            style={
                "padding": "6px 12px",
                "borderRadius": "6px",
                "border": "1px solid #d1d5db",
                "background": "#fff",
                "cursor": "pointer" if page > 0 else "default"
            }
        ),
        html.Span(
            f"Page {page + 1} / {max(1, total_pages)} ({total_poi} POI)",
            style={"margin": "0 12px", "fontSize": "0.9rem"}
        ),
        html.Button(
            "Suivant ▶",
            id="poi-next",
            disabled=(page >= total_pages - 1),
            style={
                "padding": "6px 12px",
                "borderRadius": "6px",
                "border": "1px solid #d1d5db",
                "background": "#fff",
                "cursor": "pointer" if page < total_pages - 1 else "default"
            }
        ),
    ]) if total_poi > page_size else html.Div()
    
    # === 3. DONNÉES CYCLABLES ===
    df_cyclables = get_cyclables()
    
    if df_cyclables is None or len(df_cyclables) == 0:
        score_info = {
            "score_total": 0,
            "niveau": ("🔴 Non cyclable", "Aucun aménagement détecté"),
            "details": {"densite": 0, "qualite": 0, "connectivite": 0, "accessibilite": 0},
            "stats": {"km_total": 0, "nb_composantes": 0, "pct_principale": 0}
        }
        banner = build_cyclability_banner(score_info)
        
        markers = [dl.Marker(
            position=center,
            children=dl.Tooltip(f"🚉 {gare_libelle}"),
            icon={
                'iconUrl': 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png',
                'shadowUrl': 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
                'iconSize': [25, 41],
                'iconAnchor': [12, 41],
            }
        )]
        
        stations_layer = []
        heatmap_data = []
        stats = [html.Div("Données non disponibles", className="stat-pill")]
        legend = []
        intermodal = build_intermodal_comparison(gare, poi_page)
        routes = build_verified_routes([])
        
        if stations_by_ville and len(stations_by_ville) > 0:
            # Prendre la ville avec le plus de stations
            ville_tendance = max(stations_by_ville.items(), key=lambda x: len(x[1]))[0]
        elif villes_detectees:
            ville_tendance = villes_detectees[0]
        else:
            ville_tendance = "Paris"  # Fallback ultime
        # Debug
        print(
            f"[mobilite] 📊 Tendances pour: {ville_tendance} "
            f"(villes détectées: {villes_detectees}, " 
            f"stations: {list(stations_by_ville.keys()) if stations_by_ville else 'aucune'})")

        trends = build_trends_chart(ville_tendance)
        trends_badge = build_collection_status_badge(ville_tendance)
        
        elapsed = time.time() - start_time
        print(f"[mobilite] ✅ Rendu (sans cyclables) en {elapsed:.2f}s")
        
        return (
            banner, velos_section, stats, center, zoom, markers, stations_layer,
            heatmap_data, legend, intermodal, routes, trends, trends_badge,
            pagination_controls, ville_tendance
        )
    
    # Filtrage spatial des aménagements cyclables
    try:
        import geopandas as gpd
        from shapely.geometry import Point
        
        point_gare = Point(gare_lon, gare_lat)
        gare_gdf = gpd.GeoDataFrame(geometry=[point_gare], crs="EPSG:4326")
        gare_l93 = gare_gdf.to_crs(epsg=2154)
        buffer_l93 = gare_l93.buffer(rayon_km * 1000)
        buffer_wgs = buffer_l93.to_crs(epsg=4326)
        
        cyclables_proches = df_cyclables[df_cyclables.intersects(buffer_wgs.iloc[0])].copy()
        print(f"[mobilite] 🚴 {len(cyclables_proches)} segments cyclables dans le rayon")
    except Exception as e:
        print(f"[mobilite] ❌ Erreur filtrage cyclables: {e}")
        cyclables_proches = df_cyclables.head(500).copy()
    
    cyclables_proches["type_norm"] = cyclables_proches["type_amenagement"].apply(normalize_type)
    
    heatmap_data = generate_heatmap_data(cyclables_proches, max_points=500)
    
    score_info = compute_cyclability_score(gare, cyclables_proches, poi_page, rayon_km)
    banner = build_cyclability_banner(score_info)
    
    routes_verified = find_verified_routes(gare, cyclables_proches, poi_page)
    routes_ui = build_verified_routes(routes_verified)
    
    ville_tendance = villes_detectees[0] if villes_detectees else "Paris"
    stations_for_trends = []
    for ville_stations in stations_by_ville.values():
        stations_for_trends.extend(ville_stations)

    trends_chart = build_trends_chart(ville_tendance, stations_for_trends)
    trends_badge = build_collection_status_badge(ville_tendance)
    
    counts = {}
    km_by_type = {}
    
    for type_key in TYPES_AMENAGEMENTS.keys():
        segs = cyclables_proches[cyclables_proches["type_norm"] == type_key]
        counts[type_key] = len(segs)
        try:
            if len(segs) > 0:
                segs_l93 = segs.to_crs(epsg=2154)
                km_by_type[type_key] = segs_l93.geometry.length.sum() / 1000
            else:
                km_by_type[type_key] = 0
        except:
            km_by_type[type_key] = 0
    
    stats = [
        html.Div(
            className="stat-pill",
            style={"borderLeftColor": "#2D6A4F"},
            children=[
                html.Div(f"{counts.get('PISTE CYCLABLE', 0)}", className="stat-value"),
                html.Div(f"Pistes ({km_by_type.get('PISTE CYCLABLE', 0):.1f} km)", className="stat-label"),
            ]
        ),
        html.Div(
            className="stat-pill",
            style={"borderLeftColor": "#1A4B8C"},
            children=[
                html.Div(f"{counts.get('BANDE CYCLABLE', 0)}", className="stat-value"),
                html.Div(f"Bandes ({km_by_type.get('BANDE CYCLABLE', 0):.1f} km)", className="stat-label"),
            ]
        ),
        html.Div(
            className="stat-pill",
            style={"borderLeftColor": "#52B788"},
            children=[
                html.Div(f"{counts.get('VOIE VERTE', 0)}", className="stat-value"),
                html.Div(f"V. vertes ({km_by_type.get('VOIE VERTE', 0):.1f} km)", className="stat-label"),
            ]
        ),
        html.Div(
            className="stat-pill",
            style={"borderLeftColor": "#F4A620"},
            children=[
                html.Div(f"{sum(counts.values())}", className="stat-value"),
                html.Div(f"Total ({sum(km_by_type.values()):.1f} km)", className="stat-label"),
            ]
        ),
    ]
    
    # Construction des calques de la carte
    markers = [
        dl.Marker(
            position=center,
            children=dl.Tooltip(f"🚉 {gare_libelle}"),
            icon={
                'iconUrl': 'https://raw.githubusercontent.com/pointhi/leaflet-color-markers/master/img/marker-icon-blue.png',
                'shadowUrl': 'https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.7.1/images/marker-shadow.png',
                'iconSize': [25, 41],
                'iconAnchor': [12, 41],
            }
        )
    ]
    
    markers.append(dl.Circle(
        center=center,
        radius=rayon_km * 1000,
        color="#666",
        weight=1,
        fill=False,
        dashArray="5,5"
    ))
    
    show_segments = "segments" in (options or [])
    if show_segments:
        segments_to_show = cyclables_proches.head(500)
        for idx, seg in segments_to_show.iterrows():
            try:
                geom = seg.geometry
                type_norm = seg.get("type_norm", "AUTRE")
                cfg = TYPES_AMENAGEMENTS.get(type_norm, TYPES_AMENAGEMENTS["AUTRE"])
                
                if geom.geom_type == "LineString":
                    coords = [[lat, lon] for lon, lat in geom.coords]
                    
                    # Calcul longueur
                    try:
                        seg_gdf = gpd.GeoDataFrame([seg], geometry='geometry', crs="EPSG:4326")
                        seg_l93 = seg_gdf.to_crs(epsg=2154)
                        longueur_m = int(seg_l93.geometry.length.iloc[0])
                    except:
                        longueur_m = int(geom.length * 111000)
                    
                    # Extraction données disponibles
                    largeur_g = seg.get("largeur_g")
                    largeur_d = seg.get("largeur_d")
                    revetement = seg.get("revetement", seg.get("revet_g"))
                    lumiere = seg.get("lumiere")
                    trafic_vit = seg.get("trafic_vit")
                    regime_g = seg.get("regime_g")
                    sens_g = seg.get("sens_g")
                    date_maj = seg.get("date_maj")
                    
                    # Construction du tooltip avec composants Dash
                    emoji_qualite = {5: "🌟", 4: "⭐", 3: "✨", 2: "💫", 1: "⚪"}
                    qualite = cfg.get('qualite', 2)
                    
                    tooltip_children = [
                        html.Div(
                            f"{cfg['emoji']} {cfg['label']}",
                            style={
                                "background": cfg["color"],
                                "color": "white",
                                "padding": "8px",
                                "borderRadius": "6px 6px 0 0",
                                "margin": "-10px -10px 8px -10px",
                                "fontWeight": "bold",
                                "fontSize": "1rem"
                            }
                        ),
                        html.Div(
                            f"📏 {longueur_m}m de long",
                            style={"padding": "4px 0"}
                        ),
                        html.Div(
                            f"{emoji_qualite[qualite]} Qualité {qualite}/5 — {cfg['description']}",
                            style={"padding": "4px 0"}
                        ),
                    ]
                    
                    # Largeur
                    if pd.notna(largeur_g) and largeur_g > 0:
                        tooltip_children.append(
                            html.Div(
                                f"↔️ Largeur: {largeur_g:.1f}m",
                                style={"padding": "4px 0", "color": "#059669"}
                            )
                        )
                    elif pd.notna(largeur_d) and largeur_d > 0:
                        tooltip_children.append(
                            html.Div(
                                f"↔️ Largeur: {largeur_d:.1f}m",
                                style={"padding": "4px 0", "color": "#059669"}
                            )
                        )
                    
                    # Revêtement
                    if pd.notna(revetement):
                        emoji_rev = "✨" if revetement == "LISSE" else "🏗️"
                        tooltip_children.append(
                            html.Div(
                                f"{emoji_rev} {revetement.title()}",
                                style={"padding": "4px 0", "color": "#0284c7"}
                            )
                        )
                    
                    # Éclairage
                    if pd.notna(lumiere):
                        if lumiere == 1.0:
                            tooltip_children.append(
                                html.Div(
                                    "💡 Éclairé",
                                    style={"padding": "4px 0", "color": "#eab308"}
                                )
                            )
                        else:
                            tooltip_children.append(
                                html.Div(
                                    "🌙 Non éclairé",
                                    style={"padding": "4px 0", "color": "#71717a"}
                                )
                            )
                    
                    # Vitesse trafic
                    if pd.notna(trafic_vit) and trafic_vit > 0:
                        tooltip_children.append(
                            html.Div(
                                f"🚗 Trafic: {int(trafic_vit)}km/h",
                                style={"padding": "4px 0", "color": "#dc2626"}
                            )
                        )
                    
                    # Régime
                    if pd.notna(regime_g) and regime_g != "AUTRE":
                        tooltip_children.append(
                            html.Div(
                                f"📋 {regime_g}",
                                style={
                                    "padding": "4px 0",
                                    "color": "#64748b",
                                    "fontSize": "0.8rem"
                                }
                            )
                        )
                    
                    # Sens
                    if pd.notna(sens_g):
                        emoji_sens = "↕️" if "BIDIRECTIONNEL" in str(sens_g).upper() else "→"
                        tooltip_children.append(
                            html.Div(
                                f"{emoji_sens} {sens_g}",
                                style={
                                    "padding": "4px 0",
                                    "color": "#64748b",
                                    "fontSize": "0.8rem"
                                }
                            )
                        )
                    
                    # Date mise à jour
                    if pd.notna(date_maj):
                        try:
                            if isinstance(date_maj, str):
                                date_str = date_maj[:10]
                            else:
                                date_str = date_maj.strftime("%Y-%m-%d")
                            tooltip_children.append(
                                html.Div(
                                    f"📅 Màj: {date_str}",
                                    style={
                                        "padding": "4px 0",
                                        "color": "#94a3b8",
                                        "fontSize": "0.75rem"
                                    }
                                )
                            )
                        except:
                            pass
                    
                    # Création du tooltip
                    tooltip = dl.Tooltip(
                        html.Div(
                            tooltip_children,
                            style={
                                "fontFamily": "system-ui",
                                "minWidth": "220px",
                                "fontSize": "0.85rem"
                            }
                        ),
                        permanent=False,
                        sticky=True
                    )
                    
                    markers.append(
                        dl.Polyline(
                            positions=coords,
                            color=cfg["color"],
                            weight=4,
                            opacity=0.7,
                            children=tooltip
                        )
                    )
            except Exception as e:
                continue
    
    show_stations = "stations" in (options or [])
    stations_layer = []
    
    if show_stations:
        for ville, stations in stations_by_ville.items():
            for s in stations:
                if not s.get('actif', True):
                    color = "#6b7280"
                elif s['velos'] == 0:
                    color = "#dc2626"
                elif s['velos'] < 3:
                    color = "#ea580c"
                else:
                    color = "#16a34a"
                
                radius = 6 + min(s['velos'], 10)
                
                # Tooltip avec composants Dash pour les stations
                tooltip_content = html.Div([
                    html.Div(
                        f"🚲 {s['reseau']}",
                        style={"fontWeight": "bold", "marginBottom": "4px"}
                    ),
                    html.Div(
                        s['nom'],
                        style={"fontSize": "0.9rem", "marginBottom": "4px"}
                    ),
                    html.Div(
                        f"🚲 {s['velos']} vélos ({s['velos_meca']} méca, {s['velos_elec']} élec)",
                        style={"color": "#16a34a"}
                    ),
                    html.Div(
                        f"🅿️ {s['places']} places libres",
                        style={"color": "#4b5563"}
                    ),
                    html.Div(
                        f"📏 {s['distance_m']}m",
                        style={"color": "#6b7280", "fontSize": "0.8rem", "marginTop": "4px"}
                    )
                ])
                
                stations_layer.append(dl.CircleMarker(
                    center=[s['lat'], s['lon']],
                    radius=radius,
                    color=color,
                    fill=True,
                    fillColor=color,
                    fillOpacity=0.7,
                    weight=2,
                    children=dl.Tooltip(tooltip_content)
                ))
    
    legend = []
    
    for cfg in TYPES_AMENAGEMENTS.values():
        legend.append(
            html.Div(
                style={"display": "flex", "alignItems": "center", "gap": "6px"},
                children=[
                    html.Div(
                        style={"width": "24px", "height": "3px", "background": cfg["color"]}
                    ),
                    html.Span(
                        f"{cfg['emoji']} {cfg['label']}",
                        style={"fontSize": "0.8rem"}
                    ),
                ]
            )
        )
    
    legend.extend([
        html.Div(
            style={"display": "flex", "alignItems": "center", "gap": "6px"},
            children=[
                html.Span("🟢", style={"color": "#16a34a"}),
                "Vélo dispo (≥3)",
            ]
        ),
        html.Div(
            style={"display": "flex", "alignItems": "center", "gap": "6px"},
            children=[
                html.Span("🟠", style={"color": "#ea580c"}),
                "Vélo faible (1-2)",
            ]
        ),
        html.Div(
            style={"display": "flex", "alignItems": "center", "gap": "6px"},
            children=[
                html.Span("🔴", style={"color": "#dc2626"}),
                "Vélo vide",
            ]
        ),
        html.Div(
            style={"display": "flex", "alignItems": "center", "gap": "6px"},
            children=[
                html.Span("⚫", style={"color": "#6b7280"}),
                "Hors service",
            ]
        ),
    ])
    
    intermodal = build_intermodal_comparison(gare, poi_page)
    
    elapsed = time.time() - start_time
    print(f"[mobilite] ✅ Rendu complet en {elapsed:.2f}s")
    
    return (
        banner, velos_section, stats, center, zoom, markers, stations_layer,
        heatmap_data, legend, intermodal, routes_ui, trends_chart, trends_badge,
        pagination_controls, ville_tendance
    )

# ═══════════════════════════════════════════════════════════════════════════════
# CALLBACKS SECONDAIRES
# ═══════════════════════════════════════════════════════════════════════════════

@callback(
    Output("poi-pagination-store", "data"),
    Input("poi-prev", "n_clicks"),
    Input("poi-next", "n_clicks"),
    State("poi-pagination-store", "data"),
    prevent_initial_call=True,
)
def update_pagination(prev_clicks, next_clicks, current):
    ctx = dash.callback_context
    if not ctx.triggered:
        return current
    
    button_id = ctx.triggered[0]["prop_id"].split(".")[0]
    page = current.get("page", 0)
    
    if button_id == "poi-prev":
        return {**current, "page": max(0, page - 1)}
    elif button_id == "poi-next":
        return {**current, "page": page + 1}
    
    return current


@callback(
    Output("heatmap-layer", "children"),
    Input("heatmap-data-store", "data"),
    Input("mob-options", "value"),
)
def update_heatmap(heatmap_data, options):
    if not heatmap_data or "heatmap" not in (options or []):
        return []

    markers = []

    for point in heatmap_data[:300]:
        try:
            lat, lon, intensity = point
        except Exception:
            print("⚠️ Format invalide:", point)
            continue

        # Couleur selon intensité
        if intensity >= 0.8:
            color = "#DC2626"
        elif intensity >= 0.6:
            color = "#EA580C"
        elif intensity >= 0.4:
            color = "#F59E0B"
        else:
            color = "#10B981"

        radius = 5 + (intensity * 10)

        markers.append(
            dl.CircleMarker(
                center=[lat, lon],
                radius=radius,
                color=color,
                fill=True,
                fillColor=color,
                fillOpacity=0.4,
                weight=0,
            )
        )

    return markers

@callback(
    Output("trends-chart", "children", allow_duplicate=True),
    Output("trends-status-badge", "children", allow_duplicate=True),
    Input("selected-ville-store", "data"),
    prevent_initial_call=True,
)
def update_trends(ville):
    if not ville:
        raise PreventUpdate
    return build_trends_chart(ville), build_collection_status_badge(ville)

@callback(
    Output("auto-refresh", "n_intervals"),
    Input("mob-gare-select", "value"),
    prevent_initial_call=True,
)
def reset_refresh_counter(_):
    """Réinitialise le compteur de rafraîchissement quand on change de gare"""
    return 0

# ═══════════════════════════════════════════════════════════════════════════════
# FONCTIONS UTILITAIRES POUR ADMIN/DEBUG (depuis mobilite_INTEGRATION_TRENDS.py)
# ═══════════════════════════════════════════════════════════════════════════════

def force_collect_now(ville: str):
    """
    Force une collecte immédiate pour une ville
    CORRECTION: Utilise get_all_stations() au lieu de collect_snapshot()
    """
    analyzer = get_trends_analyzer()
    if not analyzer:
        print("[mobilite] ❌ Analyseur non disponible")
        return 0
    
    async def collect():
        try:
            # Récupérer les stations pour la ville
            stations = await gbfs_client.get_all_stations(cities=[ville])
            
            # Si l'analyzer a une méthode process_stations, l'utiliser
            if hasattr(analyzer, 'process_stations'):
                count = await analyzer.process_stations(ville, stations)
            else:
                # Fallback: juste compter
                count = len(stations)
                print(f"[mobilite] ✅ Collecte manuelle: {ville} - {count} stations (sans stockage)")
            
            return count
        except Exception as e:
            print(f"[mobilite] ❌ Erreur collecte: {e}")
            return 0
    
    return loop_manager.run_async(collect())

def get_collection_stats():
    """Récupère les statistiques de collecte pour debug"""
    analyzer = get_trends_analyzer()
    if not analyzer:
        return "Analyseur non disponible"
    
    try:
        stats = []
        for ville in ["Paris", "Lyon", "Marseille", "Bordeaux"]:
            status = analyzer.get_collection_status(ville)
            stats.append(f"{ville}: {status}")
        return "\n".join(stats)
    except Exception as e:
        return f"Erreur: {e}"

# Nettoyage automatique à la fermeture
def cleanup_on_exit():
    """Nettoie les ressources à l'arrêt"""
    print("[mobilite] 🧹 Nettoyage...")
    try:
        if _trends_analyzer:
            _trends_analyzer.stop_collector()
            _trends_analyzer.cleanup_old_data(jours_conservation=30)
        loop_manager._executor.shutdown(wait=False)
    except Exception as e:
        print(f"[mobilite] ⚠️ Erreur nettoyage: {e}")

atexit.register(cleanup_on_exit)