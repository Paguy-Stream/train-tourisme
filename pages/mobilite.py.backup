def build_cyclability_banner(score_info):
    score = score_info["score_total"]
    niveau, description = score_info["niveau"]
    details = score_info["details"]
    stats = score_info["stats"]
    
    colors = {
        (75, 100): ("#2D6A4F", "#D1FAE5"),
        (55, 74):  ("#1A4B8C", "#DBEAFE"),
        (35, 54):  ("#F4A620", "#FEF3C7"),
        (15, 34):  ("#E85D04", "#FFE4D6"),
        (0, 14):   ("#9D0208", "#FEE2E2"),
    }
    
    for (min_s, max_s), (border_color, bg_color) in colors.items():
        if min_s <= score <= max_s:
            break
    
    def _badge(emoji, label, score_val):
        return html.Div(style={
            "display": "flex", "alignItems": "center", "gap": "6px",
            "background": "rgba(255,255,255,0.8)", "padding": "6px 12px",
            "borderRadius": "20px", "fontSize": "0.8rem",
            "border": "1px solid rgba(0,0,0,0.05)",
        }, children=[
            html.Span(emoji),
            html.Span(label, style={"fontWeight": "500"}),
            html.Span(f"({score_val})", style={"color": "#6B7280", "fontSize": "0.75rem"}),
        ])
    
    return html.Div(style={
        "background": f"linear-gradient(135deg, {bg_color}, #fff)",
        "borderLeft": f"5px solid {border_color}",
        "borderRadius": "12px", "padding": "20px 24px",
        "display": "flex", "alignItems": "center",
        "gap": "24px", "flexWrap": "wrap",
    }, children=[
        html.Div(style={
            "width": "80px", "height": "80px", "borderRadius": "50%",
            "background": border_color, "display": "flex",
            "flexDirection": "column", "alignItems": "center",
            "justifyContent": "center", "color": "white",
        }, children=[
            html.Div(f"{score}", style={"fontSize": "2rem", "fontWeight": "800"}),
            html.Div("/100", style={"fontSize": "0.7rem", "opacity": "0.9"}),
        ]),
        html.Div(style={"flex": "1", "minWidth": "200px"}, children=[
            html.H4(niveau, style={"color": border_color, "marginBottom": "4px"}),
            html.P(description, style={"color": "#4B5563", "fontSize": "0.9rem", "marginBottom": "12px"}),
            html.Div(style={"display": "flex", "gap": "12px", "flexWrap": "wrap"}, children=[
                _badge("📏", f"{stats['km_total']} km", f"{details['densite']:.0f}/30"),
                _badge("⭐", "Qualité", f"{details['qualite']:.0f}/25"),
                _badge("🔗", f"{stats['nb_composantes']} réseaux", f"{details['connectivite']:.0f}/25"),
                _badge("📍", "Accessibilité", f"{details['accessibilite']:.0f}/20"),
            ]),
        ]),
        html.Div(style={"textAlign": "center"}, children=[
            html.Div(
                "🚴 Recommandé" if score >= 55 else "🚲 Possible" if score >= 35 else "⚠️ Difficile",
                style={
                    "padding": "10px 16px", "background": border_color,
                    "color": "white", "borderRadius": "8px", "fontWeight": "600",
                }
            ),
        ]),
    ])

def build_velo_section_avancee(stations_by_ville, villes, gare_nom, radius_km=None):
    """
    Version avancée avec graphiques et analytics
    """
    total_stations_globales = sum(len(stations) for stations in (stations_by_ville or {}).values())
    
    # CAS SPÉCIAL: Des villes mais peu de stations dans le rayon
    if not villes or not stations_by_ville or total_stations_globales == 0:
        message = []
        
        if villes and radius_km:
            message.extend([
                html.Div(f"ℹ️ Aucune station dans un rayon de {radius_km}km", 
                        style={"fontWeight": "500", "color": "#4b5563"}),
                html.Div(f"Services disponibles dans la région: {', '.join(villes)}", 
                        style={"fontSize": "0.8rem", "color": "#6b7280", "marginTop": "4px"}),
            ])
            
            # SUGGESTION CONTEXTUELLE
            if any(v in ['Paris', 'Lyon', 'Marseille', 'Bordeaux', 'GPSEO', 'SIEMU'] for v in villes):
                message.append(
                    html.Div([
                        "💡 Ce quartier a peu de stations, mais le réseau est dense. ",
                        html.Br(),
                        "Essayez d'augmenter le rayon à 10km pour voir plus d'options."
                    ], style={"fontSize": "0.8rem", "color": "#92400E", "marginTop": "8px", 
                             "background": "#FEF3C7", "padding": "8px 12px", "borderRadius": "6px"})
                )
            else:
                message.append(
                    html.Div("💡 Essayez d'augmenter le rayon d'analyse à 10km", 
                            style={"fontSize": "0.8rem", "color": "#92400E", "marginTop": "8px"})
                )
        else:
            message = [html.Div(f"ℹ️ Aucun service de vélos en libre-service à {gare_nom}", 
                               style={"fontWeight": "500", "color": "#4b5563"})]
        
        return html.Div(style={
            "padding": "16px", 
            "background": "#f3f4f6",
            "borderRadius": "8px", 
            "borderLeft": "4px solid #9ca3af",
        }, children=message)
    
    # MESSAGE INFORMATIF: Si peu de stations mais des villes
    info_banner = None
    if total_stations_globales < 5 and len(villes) > 1:
        info_banner = html.Div(
            f"ℹ️ Seulement {total_stations_globales} stations très proches, "
            f"mais {len(villes)} services disponibles dans la région",
            style={
                "fontSize": "0.8rem", "color": "#1E3A8A", "marginBottom": "12px",
                "background": "#DBEAFE", "padding": "8px 12px", "borderRadius": "6px"
            }
        )
    
    all_sections = []
    if info_banner:
        all_sections.append(info_banner)
    
    total_vehicles = 0
    total_stations = 0
    
    # N'afficher que les villes qui ont des stations
    villes_avec_stations = {v: s for v, s in stations_by_ville.items() if len(s) > 0}
    
    for ville, stations in villes_avec_stations.items():
        total_stations += len(stations)
        total_vehicles += sum(s['velos'] for s in stations)
        
        # Compter par type
        n_stations = len([s for s in stations if s['type'] == 'station'])
        n_free = len([s for s in stations if s['type'] == 'free_floating'])
        
        # Calculer les totaux par type de véhicule
        total_meca = sum(s['velos_meca'] for s in stations)
        total_elec = sum(s['velos_elec'] for s in stations)
        total_scooters = sum(s['scooters'] for s in stations)
        
        # Pie chart conditionnel
        values_pie = []
        labels_pie = []
        colors_pie = []
        
        if total_meca > 0:
            values_pie.append(total_meca)
            labels_pie.append('Vélos méca')
            colors_pie.append('#2D6A4F')
        if total_elec > 0:
            values_pie.append(total_elec)
            labels_pie.append('Vélos élec')
            colors_pie.append('#1A4B8C')
        if total_scooters > 0:
            values_pie.append(total_scooters)
            labels_pie.append('Scooters')
            colors_pie.append('#E85D04')
        
        if values_pie:
            fig_pie = go.Figure(data=[go.Pie(
                labels=labels_pie,
                values=values_pie,
                marker_colors=colors_pie,
                hole=0.6,
                textinfo='none'
            )])
            fig_pie.update_layout(
                showlegend=False,
                margin=dict(l=0, r=0, t=0, b=0),
                height=80,
                paper_bgcolor='rgba(0,0,0,0)',
                plot_bgcolor='rgba(0,0,0,0)',
                annotations=[dict(text=f"{sum(values_pie)}", x=0.5, y=0.5, 
                                font_size=14, showarrow=False)]
            )
            pie_chart = dcc.Graph(figure=fig_pie, config={'displayModeBar': False}, 
                                 style={"width": "80px", "height": "80px"})
        else:
            pie_chart = html.Div("🚲", style={"fontSize": "2rem", "width": "80px", "textAlign": "center"})
        
        # Liste des stations
        rows = []
        for s in sorted(stations, key=lambda x: x['distance_m'])[:8]:
            if not s.get('actif', True):
                color, status = "#6b7280", "Hors service"
            elif s['velos'] == 0:
                color, status = "#dc2626", "0 vélo"
            elif s['velos'] < 3:
                color, status = "#ea580c", f"{s['velos']} vélos"
            else:
                color, status = "#16a34a", f"{s['velos']} vélos"
            
            type_icone = "🅿️" if s.get("type") == "station" else "📍"
            occupation_width = min(s.get('occupation', 0), 100)
            
            rows.append(html.Div(style={
                "marginBottom": "8px", "padding": "8px",
                "background": "#f9fafb", "borderRadius": "6px",
                "borderLeft": f"3px solid {color}"
            }, children=[
                html.Div(style={
                    "display": "flex", "justifyContent": "space-between",
                    "marginBottom": "4px"
                }, children=[
                    html.Div([
                        html.Span(f"{type_icone} {s['nom'][:25]}...", 
                                 style={"fontWeight": "500", "fontSize": "0.85rem"}),
                        html.Div(f"{s['distance_m']}m • {s['reseau']}", 
                                style={"fontSize": "0.7rem", "color": "#6b7280"}),
                    ]),
                    html.Div(status, style={"color": color, "fontWeight": "600", "fontSize": "0.85rem"}),
                ]),
                html.Div(style={
                    "width": "100%", "height": "4px", "background": "#e5e7eb",
                    "borderRadius": "2px", "marginTop": "4px"
                }, children=[
                    html.Div(style={
                        "width": f"{occupation_width}%", "height": "4px",
                        "background": color, "borderRadius": "2px"
                    })
                ])
            ]))
        
        # Section complète
        section = html.Div([
            html.Div(style={
                "display": "flex", "justifyContent": "space-between",
                "alignItems": "center", "marginBottom": "12px"
            }, children=[
                html.Div(style={"flex": "1"}, children=[
                    html.H6(f"🚲 {ville}", style={"margin": 0, "fontSize": "1rem"}),
                    html.Span(f"{n_stations} stations, {n_free} free-floating",
                             style={"fontSize": "0.7rem", "color": "#6b7280"}),
                ]),
                pie_chart,
            ]),
            
            html.Div(style={
                "display": "grid", 
                "gridTemplateColumns": "repeat(3, 1fr)" if total_scooters > 0 else "repeat(2, 1fr)",
                "gap": "8px", "marginBottom": "12px"
            }, children=[
                html.Div(style={
                    "background": "#f0fdf4", "padding": "8px",
                    "borderRadius": "6px", "textAlign": "center"
                }, children=[
                    html.Div("🚲 Méca", style={"fontSize": "0.7rem", "color": "#166534"}),
                    html.Div(f"{total_meca}", style={"fontWeight": "600", "color": "#166534"}),
                ]),
                html.Div(style={
                    "background": "#dbeafe", "padding": "8px",
                    "borderRadius": "6px", "textAlign": "center"
                }, children=[
                    html.Div("⚡ Élec", style={"fontSize": "0.7rem", "color": "#1e3a8a"}),
                    html.Div(f"{total_elec}", style={"fontWeight": "600", "color": "#1e3a8a"}),
                ]),
                html.Div(style={
                    "background": "#ffedd5", "padding": "8px",
                    "borderRadius": "6px", "textAlign": "center"
                }, children=[
                    html.Div("🛴 Trott.", style={"fontSize": "0.7rem", "color": "#9a3412"}),
                    html.Div(f"{total_scooters}", style={"fontWeight": "600", "color": "#9a3412"}),
                ]) if total_scooters > 0 else None,
            ]),
            
            html.Div(rows, style={"maxHeight": "250px", "overflowY": "auto"}),
            
        ], style={"marginBottom": "16px", "padding": "16px", "background": "#fff", 
                 "borderRadius": "8px", "border": "1px solid #e5e7eb"})
        
        all_sections.append(section)
    
    # En-tête avec stats globales
    villes_actives = len(villes_avec_stations)
    header = html.Div(style={
        "display": "flex", "justifyContent": "space-between",
        "alignItems": "center", "marginBottom": "16px", "padding": "0 4px"
    }, children=[
        html.Div([
            html.H5("🚲 Vélos en libre-service", style={"margin": 0}),
            html.Span(f"{villes_actives}/{len(villes)} villes • {total_stations} points",
                     style={"fontSize": "0.8rem", "color": "#6b7280"}),
        ]),
        html.Div(style={
            "background": "#f0fdf4", "padding": "8px 16px",
            "borderRadius": "20px", "textAlign": "center"
        }, children=[
            html.Div("Disponibles", style={"fontSize": "0.7rem", "color": "#166534"}),
            html.Div(f"{total_vehicles}", style={"fontSize": "1.5rem", "fontWeight": "700", "color": "#166534"}),
        ]),
    ])
    
    return html.Div([
        header,
        html.Div(all_sections, style={"maxHeight": "500px", "overflowY": "auto"}),
    ])


def build_verified_routes(routes_verified):
    if not routes_verified:
        return html.P("Aucun itinéraire vérifié trouvé dans ce rayon.",
                     style={"color": "#9CA3AF", "fontSize": "0.85rem"})
    
    cards = []
    for route in routes_verified:
        cards.append(html.Div(style={
            "padding": "14px",
            "background": "#f8fafc",
            "borderRadius": "8px",
            "borderLeft": f"4px solid {route['color']}",
            "marginBottom": "8px",
        }, children=[
            html.Div(style={
                "display": "flex", "justifyContent": "space-between",
                "marginBottom": "8px"
            }, children=[
                html.Div(route['destination'], style={"fontWeight": "600", "fontSize": "0.9rem"}),
                html.Span(route['type'], style={"fontSize": "0.7rem", "color": "#6b7280"}),
            ]),
            html.Div(style={
                "display": "flex", "gap": "12px",
                "fontSize": "0.75rem", "color": "#6B7280",
                "flexWrap": "wrap",
            }, children=[
                html.Span(f"📏 {route['distance_km']} km"),
                html.Span(f"⏱️ {route['temps_min']} min"),
                html.Span(f"🛡️ {route['pct_couvert']}% sécurisé"),
                html.Span(route['qualite'], style={"color": route['color'], "fontWeight": "600"}),
            ]),
        ]))
    
    return html.Div(cards)

def build_intermodal_comparison(gare_row, df_poi_local):
    """Comparateur intermodal avec calculs RÉALISTES urbains"""
    
    # ✅ CALCUL DISTANCE ROBUSTE AVEC FALLBACKS MULTIPLES
    distance_km = None
    
    # Tentative 1 : Utiliser les POIs fournis
    if df_poi_local is not None and len(df_poi_local) > 0:
        # S'assurer que distance_km existe
        if "distance_km" not in df_poi_local.columns:
            df_poi_local = df_poi_local.copy()
            df_poi_local["distance_km"] = df_poi_local.apply(
                lambda r: compute_distance_km(
                    gare_row["latitude"], gare_row["longitude"],
                    r["latitude"], r["longitude"]
                ), axis=1
            )
        
        distances = df_poi_local["distance_km"].tolist()
        distances_filtrees = [d for d in distances if 0.5 <= d <= 5.0]
        
        if distances_filtrees:
            distance_km = np.median(distances_filtrees)
            print(f"[mobilite] 📍 Distance POI médiane: {distance_km:.1f}km ({len(distances_filtrees)} POIs)")
        elif distances:
            distance_km = np.percentile(distances, 60)
            print(f"[mobilite] 📍 Distance POI percentile: {distance_km:.1f}km")
    
    # Tentative 2 : Si pas de POIs dans poi_page, charger TOUS les POIs de la gare
    if distance_km is None:
        print(f"[mobilite] ⚠️ Aucun POI dans poi_page, rechargement complet...")
        try:
            poi_complets = filter_poi_by_bbox(
                get_poi(),  # Tous les POIs
                gare_row["latitude"], 
                gare_row["longitude"], 
                5.0  # Rayon de 5km
            )
            
            if len(poi_complets) > 0:
                poi_complets["distance_km"] = poi_complets.apply(
                    lambda r: compute_distance_km(
                        gare_row["latitude"], gare_row["longitude"],
                        r["latitude"], r["longitude"]
                    ), axis=1
                )
                
                distances = poi_complets["distance_km"].tolist()
                distances_filtrees = [d for d in distances if 0.5 <= d <= 5.0]
                
                if distances_filtrees:
                    distance_km = np.median(distances_filtrees)
                    print(f"[mobilite] 📍 Distance POI (rechargé): {distance_km:.1f}km")
        except Exception as e:
            print(f"[mobilite] ❌ Erreur rechargement POIs: {e}")
    
    # Tentative 3 : Estimation géographique (ville vs campagne)
    if distance_km is None:
        gare_nom = gare_row.get("libelle", "").lower()
        
        # Grandes villes : centre proche
        if any(v in gare_nom for v in ["paris", "lyon", "marseille", "lille", "bordeaux", "toulouse", "nantes", "strasbourg", "montpellier", "nice", "rennes", "grenoble"]):
            distance_km = 1.5
            print(f"[mobilite] 📍 Distance estimée (grande ville): {distance_km}km")
        
        # Villes moyennes
        elif any(v in gare_nom for v in ["mulhouse", "nancy", "rouen", "avignon", "brest", "angers", "limoges", "metz", "reims", "dijon"]):
            distance_km = 2.0
            print(f"[mobilite] 📍 Distance estimée (ville moyenne): {distance_km}km")
        
        # Petites villes / campagne
        else:
            distance_km = 2.5
            print(f"[mobilite] 📍 Distance estimée (défaut): {distance_km}km")
    
    # Limiter entre 0.8 et 5.0 km
    distance_km = round(max(0.8, min(distance_km, 5.0)), 1)
    
    print(f"[mobilite] 🎯 Distance finale utilisée: {distance_km}km pour {gare_row.get('libelle', 'gare')}")
    
    # ✅ VITESSES RÉALISTES EN MILIEU URBAIN DENSE
    vitesse_velo = 14   # km/h (avec feux, OK)
    vitesse_marche = 5  # km/h (standard)
    vitesse_bus = 11    # km/h (lent avec arrêts)
    
    # ✅ TAXI : Vitesse qui DIMINUE avec la congestion urbaine
    if distance_km <= 1.5:
        vitesse_taxi = 10  # km/h (congestion extrême, centre-ville)
    elif distance_km <= 3.0:
        vitesse_taxi = 15  # km/h (congestion modérée)
    else:
        vitesse_taxi = 20  # km/h (périphérie)
    
    # ✅ TEMPS AVEC PRISES EN CHARGE RÉALISTES
    temps_velo = max(4, round((distance_km / vitesse_velo) * 60 + 2))
    temps_marche = max(8, round((distance_km / vitesse_marche) * 60))
    temps_bus = max(10, round((distance_km / vitesse_bus) * 60 + 8))
    
    temps_deplacement_taxi = (distance_km / vitesse_taxi) * 60
    
    if distance_km <= 1.5:
        temps_taxi = max(8, round(temps_deplacement_taxi + 5))
    elif distance_km <= 3.0:
        temps_taxi = max(7, round(temps_deplacement_taxi + 3))
    else:
        temps_taxi = max(6, round(temps_deplacement_taxi + 2))
    
    # CO2 et coûts
    co2_bus = round(distance_km * 95)
    co2_taxi = round(distance_km * 180)
    co2_velo = 0
    co2_marche = 0
    
    cout_bus = 1.70
    cout_taxi = round(7.50 + (distance_km * 1.90), 2)
    cout_velo = 0
    cout_marche = 0
    
    # Création des modes
    modes = [
        {
            "mode": "🚴 Vélo",
            "temps": temps_velo,
            "co2": co2_velo,
            "cout": cout_velo,
            "color": "#2D6A4F",
            "vitesse": vitesse_velo,
            "description": "Le plus rapide et écologique"
        },
        {
            "mode": "🚕 Taxi",
            "temps": temps_taxi,
            "co2": co2_taxi,
            "cout": cout_taxi,
            "color": "#E85D04",
            "vitesse": vitesse_taxi,
            "description": "Pratique mais coûteux et lent en ville"
        },
        {
            "mode": "🚌 Bus",
            "temps": temps_bus,
            "co2": co2_bus,
            "cout": cout_bus,
            "color": "#1A4B8C",
            "vitesse": vitesse_bus,
            "description": "Économique mais lent"
        },
        {
            "mode": "🚶 Marche",
            "temps": temps_marche,
            "co2": co2_marche,
            "cout": cout_marche,
            "color": "#52B788",
            "vitesse": vitesse_marche,
            "description": "Santé et écologie"
        },
    ]
    
    modes.sort(key=lambda x: x["temps"])
    
    # Graphique
    fig = go.Figure()
    
    for m in modes:
        fig.add_trace(go.Bar(
            name=m['mode'],
            x=[m['mode']],
            y=[m['temps']],
            marker_color=m['color'],
            text=f"{m['temps']} min",
            textposition='outside',
            hovertemplate=(
                f"<b>{m['mode']}</b><br>" +
                f"Distance: {distance_km:.1f} km<br>" +
                f"Vitesse: {m['vitesse']} km/h<br>" +
                f"Temps: {m['temps']} min<br>" +
                f"CO₂: {m['co2']} g<br>" +
                f"Coût: {m['cout']:.2f}€<br>" +
                f"<i>{m['description']}</i><extra></extra>"
            )
        ))
    
    fig.update_layout(
        barmode='group',
        height=220,
        margin=dict(l=40, r=20, t=40, b=20),
        showlegend=False,
        plot_bgcolor='rgba(0,0,0,0)',
        paper_bgcolor='rgba(0,0,0,0)',
        yaxis_title="Temps (minutes)",
        yaxis=dict(gridcolor='rgba(0,0,0,0.1)'),
        font=dict(size=11),
        annotations=[dict(
            x=0.5, y=1.15,
            xref='paper', yref='paper',
            text=f"Distance estimée : {distance_km:.1f} km",
            showarrow=False,
            font=dict(size=12, color='#374151')
        )]
    )
    
    # Tableau
    rows = []
    header = html.Div(
        f"📍 Distance vers centre-ville : {distance_km:.1f} km",
        style={
            "fontSize": "0.9rem",
            "color": "#4B5563",
            "marginBottom": "12px",
            "padding": "8px 12px",
            "background": "#F3F4F6",
            "borderRadius": "6px",
            "textAlign": "center"
        }
    )
    
    for rank, m in enumerate(modes, 1):
        is_best = rank == 1
        ecart = m['temps'] - modes[0]['temps'] if not is_best else 0
        
        rows.append(html.Div(style={
            "display": "flex",
            "alignItems": "center",
            "gap": "12px",
            "padding": "10px 14px",
            "background": m['color'] if is_best else "#f8fafc",
            "borderRadius": "8px",
            "marginBottom": "6px",
            "border": f"2px solid {m['color']}" if is_best else "1px solid #e5e7eb",
            "color": "white" if is_best else "inherit"
        }, children=[
            html.Div(style={"display": "flex", "alignItems": "center", "gap": "8px", "width": "90px"}, children=[
                html.Span(f"#{rank}", style={
                    "fontWeight": "800",
                    "fontSize": "0.9rem",
                    "opacity": "0.8" if not is_best else "1"
                }),
                html.Span(m['mode'], style={"fontWeight": "600", "fontSize": "0.9rem"})
            ]),
            
            html.Div(style={"flex": "1", "display": "flex", "gap": "16px", "alignItems": "center"}, children=[
                html.Span(f"⏱️ {m['temps']} min", style={
                    "fontWeight": "700" if is_best else "500",
                    "fontSize": "0.95rem"
                }),
                html.Span(f"💰 {m['cout']:.2f}€" if m['cout'] > 0 else "🌱 Gratuit", 
                         style={"fontSize": "0.85rem", "opacity": "0.9"}),
                html.Span(f"🌱 {m['co2']}g CO₂", 
                         style={"fontSize": "0.85rem", "opacity": "0.9"}),
            ]),
            
            html.Div(
                "✓ Recommandé" if is_best else f"+{ecart} min",
                style={
                    "background": "rgba(255,255,255,0.2)" if is_best else "#F3F4F6",
                    "color": "white" if is_best else "#6B7280",
                    "padding": "4px 10px",
                    "borderRadius": "12px",
                    "fontSize": "0.75rem",
                    "fontWeight": "600",
                }
            ) if is_best or ecart > 2 else html.Div(
                f"+{ecart} min",
                style={"fontSize": "0.75rem", "color": "#9CA3AF"}
            ),
        ]))
    
    return html.Div([
        header,
        dcc.Graph(figure=fig, config={'displayModeBar': False}, style={"marginTop": "8px"}),
        html.Div(rows, style={"marginTop": "12px"})
    ])

def normalize_type(type_str):
    if pd.isna(type_str):
        return "AUTRE"
    t = str(type_str).upper()
    if "PISTE" in t:
        return "PISTE CYCLABLE"
    elif "BANDE" in t:
        return "BANDE CYCLABLE"
    elif "VOIE VERTE" in t or "VERTE" in t:
        return "VOIE VERTE"
    return "AUTRE"

