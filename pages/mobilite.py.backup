def detecter_villes_gbfs(gare_nom: str) -> List[str]:
    """Détecte les villes avec mapping intelligent et exclusions géographiques"""
    gare_nom_lower = gare_nom.lower()
    villes_detectees = []
    
    # Récupérer villes disponibles
    try:
        villes_disponibles = gbfs_client.get_cities_list()
    except Exception as e:
        print(f"[mobilite] ❌ Erreur récupération villes: {e}")
        villes_disponibles = []
    
    # Chercher correspondances par ORDRE DE SPÉCIFICITÉ
    ordered_keywords = [
        # === 1. ZONES SPÉCIFIQUES (priorité maximale) ===
        ("evry", ["GPSEO"]),
        ("corbeil", ["GPSEO"]),
        ("mennecy", ["GPSEO"]),
        ("ris-orangis", ["GPSEO"]),
        ("gpseo", ["GPSEO"]),
        ("grand paris sud", ["GPSEO"]),
        
        ("melun", ["SIEMU"]),
        ("dammarie-les-lys", ["SIEMU"]),
        ("siemu", ["SIEMU"]),
        
        ("marseille saint-charles", ["Marseille"]),
        ("marseille blancarde", ["Marseille"]),
        ("marseille joliette", ["Marseille"]),
        ("vitrolles aéroport marseille", ["Marseille"]),
        
        # === 2. GRANDES MÉTROPOLES ===
        ("paris", ["Paris"]),
        ("lyon", ["Lyon"]),
        ("marseille", ["Marseille"]),
        ("nice", ["Nice"]),
        ("lille", ["Lille"]),
        ("bordeaux", ["Bordeaux"]),
        ("toulouse", ["Toulouse"]),
        ("nantes", ["Nantes"]),
        ("strasbourg", ["Strasbourg"]),
        ("rennes", ["Rennes"]),
        ("grenoble", ["Grenoble"]),
        
        # === 3. ✅ NOUVELLES VILLES (7 ajoutées) ===
        ("montpellier", ["Montpellier"]),
        ("nimes", ["Nîmes"]),
        ("nîmes", ["Nîmes"]),  # Variante avec accent
        ("nancy", ["Nancy"]),
        ("le havre", ["Le Havre"]),
        ("havre", ["Le Havre"]),
        ("mulhouse", ["Mulhouse"]),
        ("rouen", ["Rouen"]),
        ("avignon", ["Avignon"]),
        
        # === 4. VILLES MOYENNES ===
        ("angers", ["Angers"]),
        ("brest", ["Brest"]),
        ("limoges", ["Limoges"]),
        ("lorient", ["Lorient"]),
        ("amiens", ["Amiens"]),
        ("poitiers", ["Poitiers"]),
        ("bourges", ["Bourges"]),
        ("saint-etienne", ["Saint-Étienne"]),
        ("saint etienne", ["Saint-Étienne"]),
    ]
    
    matched_keywords = []
    
    for mot_cle, villes_associees in ordered_keywords:
        if mot_cle in gare_nom_lower:
            for ville in villes_associees:
                if ville in villes_disponibles and ville not in villes_detectees:
                    villes_detectees.append(ville)
                    matched_keywords.append(mot_cle)
                    print(f"[mobilite] ✅ Détecté: {ville} via mot-clé '{mot_cle}'")
            
            # Arrêter si on a trouvé une correspondance spécifique
            if mot_cle not in ["paris", "lyon", "marseille", "lille", "bordeaux", "toulouse"]:
                break
    
    # Fallback si rien trouvé
    if not villes_detectees:
        for ville in villes_disponibles:
            ville_lower = ville.lower()
            if ville_lower in gare_nom_lower:
                # Vérification pour éviter confusion Paris/GPSEO
                if ville == "Paris" and ("gpseo" in gare_nom_lower or "evry" in gare_nom_lower):
                    continue
                villes_detectees.append(ville)
                print(f"[mobilite] ✅ Détecté (fallback): {ville}")

    villes_detectees = list(set(villes_detectees))
    
    # Log final
    if len(villes_detectees) > 1:
        print(f"[mobilite] 📍 Villes détectées: {villes_detectees} (multi-villes)")
    else:
        print(f"[mobilite] 📍 Ville détectée: {villes_detectees[0] if villes_detectees else 'Aucune'}")
    
    return villes_detectees


def get_stations_proximite(villes: List[str], lat: float, lon: float, 
                           radius_km: float = 0.5) -> Dict[str, List[Dict]]:
    """
    Récupère les stations GBFS à proximité avec cache
    """
    if not villes:
        return {}
    
    cache_key = hashlib.md5(
        f"{'_'.join(sorted(villes))}_{lat:.4f}_{lon:.4f}_{radius_km}".encode()
    ).hexdigest()
    
    cached = _api_cache.get(f"gbfs_{cache_key}")
    if cached:
        total_in_cache = sum(len(stations) for stations in cached.values())
        villes_in_cache = len(cached)
        print(f"[mobilite] 🔵 GBFS cache hit: {total_in_cache} points dans {villes_in_cache} villes")
        return cached
    
    try:
        all_stations = loop_manager.run_async(
            gbfs_client.get_all_stations(cities=villes)
        )
        
        # Organiser par ville et filtrer par distance
        resultats = {}
        total_avant_filtre = len(all_stations)
        stations_par_ville_avant = {}
        
        for station in all_stations:
            if not station.lat or not station.lon:
                continue
            
            # Compter avant filtre pour le log
            if station.city not in stations_par_ville_avant:
                stations_par_ville_avant[station.city] = 0
            stations_par_ville_avant[station.city] += 1
            
            dist = compute_distance_km(lat, lon, station.lat, station.lon)
            
            if dist <= radius_km:
                if station.city not in resultats:
                    resultats[station.city] = []
                
                total_vehicles = (
                    station.num_bikes_available + 
                    station.num_ebikes_available + 
                    station.num_scooters_available
                )
                
                resultats[station.city].append({
                    "id": station.station_id,
                    "nom": station.name[:40] + "..." if len(station.name) > 40 else station.name,
                    "lat": station.lat,
                    "lon": station.lon,
                    "distance_m": int(dist * 1000),
                    "velos": total_vehicles,
                    "velos_meca": station.num_bikes_available,
                    "velos_elec": station.num_ebikes_available,
                    "scooters": station.num_scooters_available,
                    "places": station.num_docks_available,
                    "capacity": station.capacity,
                    "actif": station.is_renting,
                    "reseau": f"{station.operator}",
                    "type": "free_floating" if station.station_id.startswith("free_") else "station",
                    "last_updated": station.last_updated,
                    "occupation": (total_vehicles / station.capacity * 100) if station.capacity > 0 else 0
                })
        
        # Trier et limiter chaque ville
        for ville in resultats:
            resultats[ville].sort(key=lambda x: x["distance_m"])
            resultats[ville] = resultats[ville][:15]
        
        # Mettre en cache
        _api_cache.set(f"gbfs_{cache_key}", resultats)
        
        total_apres_filtre = sum(len(stations) for stations in resultats.values())
        villes_avec_stations = len(resultats)
        
        # LOG AMÉLIORÉ: Montrer le détail par ville
        detail_villes = ", ".join([
            f"{ville}:{len(stations)}" for ville, stations in resultats.items()
        ]) if resultats else "aucune"
        
        print(f"[mobilite] ✅ GBFS: {total_avant_filtre} stations récupérées, "
              f"{total_apres_filtre} dans le rayon ({radius_km}km) "
              f"→ [{detail_villes}]")
        
        # ALERTE SI PEU DE STATIONS: Suggérer d'augmenter le rayon
        if total_apres_filtre < 5 and total_avant_filtre > 100:
            print(f"[mobilite] ⚠️ Peu de stations proches ({total_apres_filtre}), "
                  f"mais {total_avant_filtre} disponibles dans la région.")
        
        return resultats
        
    except Exception as e:
        print(f"[mobilite] ❌ Erreur GBFS: {e}")
        import traceback
        traceback.print_exc()
        return {}

# ═══════════════════════════════════════════════════════════════════════════════
# FONCTIONS ANALYSE CYCLABILITÉ (OPTIMISÉES AVEC THREADING)
# ═══════════════════════════════════════════════════════════════════════════════

def compute_network_connectivity_vectorized(gdf_cyclables):
    """Calcule la connectivité du réseau (version optimisée)"""
    try:
        import networkx as nx
        if len(gdf_cyclables) == 0:
            return 0, 0, 0
        
        # Utiliser un graphe non dirigé pour la connectivité
        G = nx.Graph()
        
        # Vectorisation de l'extraction des nœuds
        def extract_edges(geom):
            try:
                coords = list(geom.coords)
                if len(coords) < 2:
                    return None
                start = (round(coords[0][0], 5), round(coords[0][1], 5))
                end = (round(coords[-1][0], 5), round(coords[-1][1], 5))
                # Éviter les self-loops
                if start == end:
                    return None
                return (start, end, geom.length)
            except Exception:
                return None
        
        # Application vectorisée
        edges = gdf_cyclables.geometry.apply(extract_edges).dropna()
        
        # Construction du graphe
        for edge in edges:
            G.add_edge(edge[0], edge[1], weight=edge[2])
        
        if G.number_of_nodes() == 0:
            return 0, 0, 0
        
        # Analyse des composantes
        composantes = list(nx.connected_components(G))
        nb_composantes = len(composantes)
        
        if nb_composantes == 0:
            return 0, 0, 0
            
        plus_grande = max(composantes, key=len)
        pct_principale = len(plus_grande) / G.number_of_nodes() * 100
        
        # Score de connectivité (0-25)
        # Moins de composantes = meilleur score
        score = max(0, (1 - (nb_composantes - 1) / 50) * 25)
        
        return score, nb_composantes, pct_principale
        
    except Exception as e:
        print(f"[mobilite] ⚠️ Erreur connectivité: {e}")
        return 10, 0, 0

def compute_cyclability_score(gare_row, df_cyclables_filtered, df_poi_local, rayon_km=5):
    """Calcule le score de cyclabilité avec mise en cache"""
    if df_cyclables_filtered is None or len(df_cyclables_filtered) == 0:
        return {
            "score_total": 0,
            "niveau": ("🔴 Non cyclable", "Aucun aménagement détecté"),
            "details": {"densite": 0, "qualite": 0, "connectivite": 0, "accessibilite": 0},
            "stats": {"km_total": 0, "nb_composantes": 0, "pct_principale": 0}
        }
    
    # Cache key basé sur les paramètres
    cache_key = f"cyclability_{rayon_km}_{hash(str(gare_row['libelle']))}"
    cached = _gis_cache.get(cache_key)
    if cached:
        return cached
    
    surface_km2 = np.pi * (rayon_km ** 2)
    
    try:
        import geopandas as gpd
        # Conversion en Lambert 93 pour calculs de distance précis
        cyclables_l93 = df_cyclables_filtered.to_crs(epsg=2154)
        km_total = cyclables_l93.geometry.length.sum() / 1000
    except Exception as e:
        print(f"[mobilite] ⚠️ Erreur calcul longueur: {e}")
        km_total = len(df_cyclables_filtered) * 0.3  # Estimation fallback
    
    # Score densité (max 30) - km de piste par km²
    densite_optimale = 5  # km/km² idéal (Paris centre ~8)
    score_densite = min((km_total / surface_km2) / densite_optimale * 30, 30)
    
    # Score qualité (max 25)
    def get_qualite(type_str):
        return TYPES_AMENAGEMENTS.get(type_str, {}).get("qualite", 2)
    
    if "type_norm" in df_cyclables_filtered.columns:
        # Calcul pondéré par longueur si possible
        try:
            lengths = cyclables_l93.geometry.length
            qualites = df_cyclables_filtered["type_norm"].apply(get_qualite)
            score_qualite = (np.average(qualites, weights=lengths) / 5) * 25
        except:
            qualites = df_cyclables_filtered["type_norm"].apply(get_qualite)
            score_qualite = (qualites.mean() / 5) * 25
    else:
        score_qualite = 10
    
    # Score connectivité (max 25) - en thread séparé si gros dataset
    if len(df_cyclables_filtered) > 1000:
        future = loop_manager.run_in_thread(
            compute_network_connectivity_vectorized, 
            df_cyclables_filtered
        )
        score_connectivite, nb_composantes, pct_principale = future.result(timeout=5)
    else:
        score_connectivite, nb_composantes, pct_principale = compute_network_connectivity_vectorized(df_cyclables_filtered)
    
    # Score accessibilité (max 20) - basé sur la longueur totale
    score_access = min(km_total / 10 * 20, 20) if km_total > 5 else km_total / 5 * 10
    
    total = score_densite + score_qualite + score_connectivite + score_access
    
    # Détermination du niveau
    if total >= 75:
        niveau = ("🌟 Excellent", "Réseau dense, connecté et de qualité")
    elif total >= 55:
        niveau = ("🚴 Bon", "Infrastructure satisfaisante")
    elif total >= 35:
        niveau = ("🚲 Moyen", "Réseau en développement")
    elif total >= 15:
        niveau = ("⚠️ Limité", "Aménagements ponctuels")
    else:
        niveau = ("🔴 Insuffisant", "Prévoir alternative")
    
    result = {
        "score_total": round(total),
        "niveau": niveau,
        "details": {
            "densite": round(score_densite, 1),
            "qualite": round(score_qualite, 1),
            "connectivite": round(score_connectivite, 1),
            "accessibilite": round(score_access, 1),
        },
        "stats": {
            "km_total": round(km_total, 1),
            "nb_composantes": nb_composantes,
            "pct_principale": round(pct_principale, 1),
        }
    }
    
    # Mettre en cache
    _gis_cache.set(cache_key, result)
    return result
def find_verified_routes(gare_row, df_cyclables_filtered, df_poi_local=None, max_routes=8):
    """
    Trouve les itinéraires vérifiés vers les POIs RÉELS.
    ✅ VERSION CORRIGÉE : Utilise les POIs, pas des destinations fictives
    """
    if df_cyclables_filtered is None or len(df_cyclables_filtered) == 0:
        return []
    
    try:
        import geopandas as gpd
        from shapely.geometry import LineString, Point
        import numpy as np
        
        routes_verified = []
        gare_point = Point(gare_row["longitude"], gare_row["latitude"])
        
        # Convertir en L93 si possible
        try:
            cyclables_l93 = df_cyclables_filtered.to_crs(epsg=2154)
        except Exception as e:
            print(f"[mobilite] ⚠️ Conversion L93 impossible: {e}")
            cyclables_l93 = df_cyclables_filtered
        
        # ✅ UTILISER LES VRAIS POIs AU LIEU DE DESTINATIONS FICTIVES
        destinations = []
        
        if df_poi_local is not None and len(df_poi_local) > 0:
            # Prendre les POIs dans un rayon de 3km maximum
            poi_proches = df_poi_local[df_poi_local["distance_km"] <= 3.0].copy()
            
            # Limiter à 24 POIs max
            if len(poi_proches) > 24:
                poi_proches = poi_proches.sample(n=24, random_state=42)
            
            for idx, poi in poi_proches.iterrows():
                destinations.append({
                    "nom": str(poi.get("nom", "Point d'intérêt")),
                    "type": str(poi.get("type", "POI")),
                    "lon": float(poi["longitude"]),
                    "lat": float(poi["latitude"]),
                    "distance_km": float(poi["distance_km"])
                })
        
        # Si pas assez de POIs, compléter avec destinations géométriques
        if len(destinations) < 8:
            print(f"[mobilite] ⚠️ Seulement {len(destinations)} POIs, génération de destinations supplémentaires")
            distances_cibles = [0.5, 1.0, 1.5, 2.0, 2.5]
            angles = [0, 45, 90, 135, 180, 225, 270, 315]
            
            for dist in distances_cibles:
                for angle in angles:
                    if len(destinations) >= 24:
                        break
                    angle_rad = np.radians(angle)
                    delta_lon = dist * np.cos(angle_rad) / (111.32 * np.cos(np.radians(gare_row["latitude"])))
                    delta_lat = dist * np.sin(angle_rad) / 111.32
                    
                    destinations.append({
                        "nom": f"Zone {['Nord', 'Nord-Est', 'Est', 'Sud-Est', 'Sud', 'Sud-Ouest', 'Ouest', 'Nord-Ouest'][angle // 45]}",
                        "type": "Zone d'intérêt",
                        "lon": gare_row["longitude"] + delta_lon,
                        "lat": gare_row["latitude"] + delta_lat,
                        "distance_km": dist
                    })
        
        # Analyser chaque destination
        for dest in destinations:
            try:
                dest_point = Point(dest["lon"], dest["lat"])
                dist_km = dest["distance_km"]
                
                buffer_size = min(0.002, max(0.001, dist_km * 0.0001))
                line = LineString([gare_point, dest_point])
                buffer = line.buffer(buffer_size)
                
                segments_intersect = df_cyclables_filtered[df_cyclables_filtered.intersects(buffer)]
                
                if len(segments_intersect) == 0:
                    continue
                
                # Calculer longueur couverte
                try:
                    seg_l93 = segments_intersect.to_crs(epsg=2154)
                    poids_qualite = {
                        "PISTE CYCLABLE": 1.0,
                        "BANDE CYCLABLE": 0.7,
                        "VOIE VERTE": 0.9,
                        "AUTRE": 0.4
                    }
                    
                    longueur_ponderee = 0
                    longueur_totale = 0
                    
                    for idx, seg in seg_l93.iterrows():
                        longueur = seg.geometry.length / 1000
                        type_seg = seg.get("type_norm", "AUTRE")
                        poids = poids_qualite.get(type_seg, 0.5)
                        longueur_totale += longueur
                        longueur_ponderee += longueur * poids
                    
                    pct_couvert = min(95, (longueur_ponderee / dist_km) * 100 * 0.9)
                except:
                    longueur_totale = len(segments_intersect) * 0.15
                    pct_couvert = min(90, (longueur_totale / dist_km) * 100)
                
                # Déterminer qualité
                if pct_couvert >= 75:
                    qualite, color, vitesse = "Sécurisé", "#2D6A4F", 15
                elif pct_couvert >= 50:
                    qualite, color, vitesse = "Majoritairement sécurisé", "#1A4B8C", 13
                elif pct_couvert >= 25:
                    qualite, color, vitesse = "Partiellement sécurisé", "#F4A620", 12
                elif pct_couvert >= 10:
                    qualite, color, vitesse = "Peu sécurisé", "#E85D04", 10
                else:
                    qualite, color, vitesse = "Non sécurisé", "#DC2626", 8
                
                temps_total = max(3, round((dist_km / vitesse) * 60 + 1))
                
                routes_verified.append({
                    "destination": str(dest["nom"]),
                    "type": str(dest["type"]),
                    "distance_km": float(round(dist_km, 1)),
                    "temps_min": int(temps_total),
                    "pct_couvert": int(pct_couvert),
                    "qualite": str(qualite),
                    "color": str(color),
                    "vitesse": int(vitesse),
                    "km_couverts": float(round(longueur_totale, 2)) if 'longueur_totale' in locals() else 0.0
                })
                
                if len(routes_verified) >= max_routes * 2:
                    break
                    
            except Exception as e:
                continue
        
        # Conversion types Python natifs
        routes_verified = [
            {k: (float(v) if isinstance(v, (np.floating, np.integer)) else 
                 int(v) if isinstance(v, (np.integer,)) else 
                 str(v) if isinstance(v, (np.str_, np.bytes_)) else v)
             for k, v in route.items()}
            for route in routes_verified
        ]
        
        # Diversifier les résultats
        securises = [r for r in routes_verified if r["pct_couvert"] >= 75]
        moyens = [r for r in routes_verified if 50 <= r["pct_couvert"] < 75]
        faibles = [r for r in routes_verified if 25 <= r["pct_couvert"] < 50]
        risques = [r for r in routes_verified if r["pct_couvert"] < 25]
        
        selection = []
        selection.extend(securises[:3])
        selection.extend(moyens[:2])
        selection.extend(faibles[:2])
        selection.extend(risques[:1])
        
        if len(selection) < max_routes:
            restants = [r for r in routes_verified if r not in selection]
            nb_manquants = max(0, max_routes - len(selection))
            selection.extend(restants[:nb_manquants])
        
        selection.sort(key=lambda x: x["pct_couvert"], reverse=True)
        
        return selection[:max_routes]
        
    except Exception as e:
        print(f"[mobilite] ⚠️ Erreur routes vérifiées: {e}")
        import traceback
        traceback.print_exc()
        return []

def generate_heatmap_data(cyclables_gdf, max_points: int = 1000):
    """Génère les données pour la heatmap"""
    if cyclables_gdf is None or len(cyclables_gdf) == 0:
        return []
    
    points = []
    step = max(1, len(cyclables_gdf) // max_points)
    
    for idx in range(0, len(cyclables_gdf), step):
        try:
            seg = cyclables_gdf.iloc[idx]
            centroid = seg.geometry.centroid
            qualite = TYPES_AMENAGEMENTS.get(seg.get("type_norm", "AUTRE"), {}).get("qualite", 2)
            intensity = qualite / 5.0
            points.append([centroid.y, centroid.x, intensity])
        except:
            continue
    
    return points

