# CIRCUIT BREAKER PATTERN (Résilience)
# ═══════════════════════════════════════════════════════════════════════════════

class CircuitState(Enum):
    CLOSED = "closed"      # Normal operation
    OPEN = "open"         # Failing, reject requests
    HALF_OPEN = "half_open"  # Testing if recovered

class CircuitBreaker:
    """Circuit breaker pour éviter les cascades de failures"""
    def __init__(self, name: str, failure_threshold: int = 5, recovery_timeout: int = 60):
        self.name = name
        self.failure_threshold = failure_threshold
        self.recovery_timeout = recovery_timeout
        self.failures = 0
        self.last_failure_time = None
        self.state = CircuitState.CLOSED
        self._lock = threading.Lock()
    
    def can_execute(self) -> bool:
        with self._lock:
            if self.state == CircuitState.CLOSED:
                return True
            elif self.state == CircuitState.OPEN:
                if time.time() - self.last_failure_time > self.recovery_timeout:
                    self.state = CircuitState.HALF_OPEN
                    print(f"[circuit:{self.name}] Half-open, testing...")
                    return True
                return False
            return True  # HALF_OPEN
    
    def record_success(self):
        with self._lock:
            if self.state == CircuitState.HALF_OPEN:
                self.state = CircuitState.CLOSED
                print(f"[circuit:{self.name}] Recovered, closed")
            self.failures = 0
    
    def record_failure(self):
        with self._lock:
            self.failures += 1
            self.last_failure_time = time.time()
            if self.failures >= self.failure_threshold:
                if self.state != CircuitState.OPEN:
                    self.state = CircuitState.OPEN
                    print(f"[circuit:{self.name}] OPEN (failures: {self.failures})")

# ═══════════════════════════════════════════════════════════════════════════════
# GESTION EVENT LOOP ET EXECUTEUR DE THREADS
# ═══════════════════════════════════════════════════════════════════════════════

class AsyncLoopManager:
    _instance = None
    _lock = threading.Lock()
    
    def __new__(cls):
        if cls._instance is None:
            with cls._lock:
                if cls._instance is None:
                    cls._instance = super().__new__(cls)
                    cls._instance._loop = None
                    cls._instance._executor = ThreadPoolExecutor(max_workers=MAX_WORKERS)
        return cls._instance
    
    def get_loop(self):
        with self._lock:
            if self._loop is None or self._loop.is_closed():
                try:
                    self._loop = asyncio.new_event_loop()
                    asyncio.set_event_loop(self._loop)
                except RuntimeError:
                    self._loop = asyncio.new_event_loop()
            return self._loop
    
    def run_async(self, coro):
        loop = self.get_loop()
        if loop.is_running():
            new_loop = asyncio.new_event_loop()
            try:
                return new_loop.run_until_complete(coro)
            finally:
                new_loop.close()
        else:
            return loop.run_until_complete(coro)
    
    def run_in_thread(self, func, *args, **kwargs):
        """Exécute une fonction bloquante dans un thread séparé"""
        return self._executor.submit(func, *args, **kwargs)

loop_manager = AsyncLoopManager()

# ═══════════════════════════════════════════════════════════════════════════════
# CACHE AVANCÉ AVEC GESTION DE MÉMOIRE
# ═══════════════════════════════════════════════════════════════════════════════

class MemoryManagedCache:
    """Cache avec compression et gestion de la mémoire"""
    def __init__(self, max_size_mb: int = 256, ttl_seconds: int = 60):
        self.max_size = max_size_mb * 1024 * 1024
        self.ttl = ttl_seconds
        self._cache = {}
        self._timestamps = {}
        self._sizes = {}
        self._lock = threading.RLock()
        self._current_size = 0
    
    def _compress(self, data: Any) -> bytes:
        return zlib.compress(json.dumps(data, default=str).encode(), level=6)
    
    def _decompress(self, data: bytes) -> Any:
        return json.loads(zlib.decompress(data).decode())
    
    def _get_size(self, obj) -> int:
        """Estime la taille en bytes"""
        if isinstance(obj, bytes):
            return len(obj)
        return sys.getsizeof(obj)
    
    def _evict_if_needed(self, required_space: int):
        """Évite les entrées les plus anciennes si nécessaire"""
        while self._current_size + required_space > self.max_size and self._cache:
            oldest_key = min(self._timestamps, key=self._timestamps.get)
            self._remove_entry(oldest_key)
    
    def _remove_entry(self, key: str):
        if key in self._cache:
            self._current_size -= self._sizes.get(key, 0)
            del self._cache[key]
            del self._timestamps[key]
            del self._sizes[key]
    
    def get(self, key: str) -> Optional[Any]:
        with self._lock:
            if key not in self._cache:
                return None
            
            # Vérifier TTL
            if time.time() - self._timestamps[key] > self.ttl:
                self._remove_entry(key)
                return None
            
            try:
                data = self._decompress(self._cache[key])
                self._timestamps[key] = time.time()  # Update access time
                return data
            except Exception as e:
                print(f"[cache] Decompression error: {e}")
                self._remove_entry(key)
                return None
    
    def set(self, key: str, value: Any) -> None:
        with self._lock:
            try:
                compressed = self._compress(value)
                size = self._get_size(compressed)
                
                # Retirer l'ancienne entrée si existe
                if key in self._cache:
                    self._current_size -= self._sizes[key]
                
                # Éviter si nécessaire
                self._evict_if_needed(size)
                
                self._cache[key] = compressed
                self._timestamps[key] = time.time()
                self._sizes[key] = size
                self._current_size += size
                
            except Exception as e:
                print(f"[cache] Compression error: {e}")

# Instances de cache
_api_cache = MemoryManagedCache(max_size_mb=512, ttl_seconds=60)
_gis_cache = MemoryManagedCache(max_size_mb=256, ttl_seconds=300)  # Cache GIS plus long

