# FONCTIONS TENDANCES (INTÉGRATION DEPUIS mobilite_INTEGRATION_TRENDS.py)
# ═══════════════════════════════════════════════════════════════════════════════

def analyze_availability_trends(ville: str, stations_data: List[Dict] = None) -> Dict:
    """
    Analyse les tendances de disponibilité pour une ville
    """
    analyzer = get_trends_analyzer()
    
    # 1. Essayer les données historiques
    if analyzer:
        try:
            trends = analyzer.get_trends(ville, jours=7)
            if trends and trends.get('is_real') and trends.get('hours'):
                print(f"[mobilite] 📊 Tendances réelles pour {ville} ({len(trends.get('hours', []))}h)")
                return trends
        except Exception as e:
            print(f"[mobilite] ⚠️ Erreur récupération tendances {ville}: {e}")
    
    # 2. Si on a des stations actuelles, créer un profil temps réel
    if stations_data and len(stations_data) > 0:
        print(f"[mobilite] 🔄 Utilisation données temps réel pour {ville} ({len(stations_data)} stations)")
        return _build_trends_from_current_data(ville, stations_data)
    
    # 3. Fallback : structure vide mais informative
    print(f"[mobilite] ⚠️ Aucune donnée disponible pour {ville}")
    return {
        "hours": [],
        "availability": [],
        "is_real": False,
        "fallback_reason": f"En attente de collecte pour {ville}",
        "ville": ville
    }

def _build_trends_from_current_data(ville: str, stations_data: List[Dict]) -> Dict:
    """
    Construit un profil horaire basé sur les données actuelles réelles
    sans inventer de fausses données.
    """
    if not stations_data:
        return None
    
    # Calculer la disponibilité actuelle réelle
    total_capacity = sum(s.get('capacity', 0) or 30 for s in stations_data)
    total_available = sum(s.get('velos', 0) or 0 for s in stations_data)
    current_ratio = (total_available / total_capacity * 100) if total_capacity > 0 else 0
    current_hour = datetime.now().hour
    
    # Pattern de variation horaire (factors, pas valeurs absolues)
    # Basé sur des études de mobilité réelles
    variation_factors = {
        0: 1.15, 1: 1.20, 2: 1.25, 3: 1.25, 4: 1.20, 5: 1.10,  # Nuit haute
        6: 0.95, 7: 0.75, 8: 0.65, 9: 0.70,  # Rush matin (basse)
        10: 0.80, 11: 0.85, 12: 0.80, 13: 0.85, 14: 0.90, 15: 0.88,  # Journée
        16: 0.75, 17: 0.60, 18: 0.55, 19: 0.65,  # Rush soir (basse)
        20: 0.75, 21: 0.85, 22: 0.95, 23: 1.05  # Soirée
    }
    
    # Appliquer les variations au ratio actuel réel
    hours = list(range(24))
    availability = []
    for h in hours:
        base = current_ratio * variation_factors[h]
        # Ajouter une petite incertitude (±3%) car c'est une projection
        noise = np.random.uniform(-3, 3) if h != current_hour else 0
        availability.append(round(max(5, min(95, base + noise)), 1))
    
    # Forcer l'heure actuelle à la valeur réelle mesurée
    availability[current_hour] = round(current_ratio, 1)
    
    # Identifier les pics
    morning_min = min(availability[7:10])
    evening_min = min(availability[17:20])
    peak_morning = 7 + availability[7:10].index(morning_min)
    peak_evening = 17 + availability[17:20].index(evening_min)
    best_time = availability.index(max(availability))
    
    return {
        "hours": hours,
        "availability": availability,
        "peak_morning": peak_morning,
        "peak_evening": peak_evening,
        "best_time": best_time,
        "current_hour": current_hour,
        "current_availability": round(current_ratio, 1),
        "total_stations": len(stations_data),
        "is_real": False,  # C'est une projection, pas des données historiques
        "data_quality": "projected_from_real",  # Mais basée sur des données réelles
        "fallback_reason": f"Projection basée sur {len(stations_data)} stations à {current_hour}h",
        "ville": ville
    }


def generate_synthetic_trends(ville: str) -> Dict:
    """Fallback : retourne structure vide au lieu de données inventées"""
    return {
        "hours": [],
        "availability": [],
        "is_real": False,
        "fallback_reason": "En attente de première collecte de données",
        "ville": ville
    }

def build_trends_chart(ville: str, stations_data: List[Dict] = None):
    """
    Graphique des tendances horaires basé sur VRAIES DONNÉES collectées
    Intégration depuis mobilite_INTEGRATION_TRENDS.py
    """
    if not ville:
        ville = "Paris"
    
    # Passer les stations actuelles
    trends = analyze_availability_trends(ville, stations_data)

    if not trends.get('hours') and stations_data:
        print(f"[mobilite] 🔄 Pas d'historique pour {ville}, utilisation données temps réel")
        trends = _build_trends_from_current_data(ville, stations_data)
    
    # Gérer le cas "pas de données"
    if not trends.get('hours'):
        return html.Div("⏳ En attente de collecte de données...", 
                       style={'padding': '20px', 'textAlign': 'center', 'color': '#6b7280'})
    
    # Déterminer la couleur selon si données réelles ou fallback
    if trends.get('is_real'):
        line_color = '#16a34a'  # Vert = historique réel
        fill_color = 'rgba(22, 163, 74, 0.1)'  # ✅ DÉFINI ICI
        data_quality = "Données historiques"
    elif trends.get('data_quality') == 'projected_from_real':
        line_color = '#3b82f6'  # Bleu = projection basée sur réel
        fill_color = 'rgba(59, 130, 246, 0.1)'  # ✅ DÉFINI ICI
        data_quality = trends.get('fallback_reason', 'Projection')
    else:
        line_color = '#9CA3AF'  # Gris = pas de données
        fill_color = 'rgba(156, 163, 175, 0.1)'  # ✅ DÉFINI ICI
        data_quality = "Aucune donnée"
    
    fig = go.Figure()
    
    # Courbe principale
    fig.add_trace(go.Scatter(
        x=trends['hours'],
        y=trends['availability'],
        mode='lines+markers' if trends.get('is_real') else 'lines',
        name='Disponibilité',
        line=dict(color=line_color, width=3),
        fill='tozeroy',
        fillcolor=fill_color,  # ✅ Maintenant défini dans tous les cas
        marker=dict(size=4) if trends.get('is_real') else None,
        hovertemplate='Heure: %{x}h<br>Disponibilité: %{y:.1f}%<extra></extra>'
    ))
    
    
    
    # Zones de pics (seulement si données réelles)
    if trends.get('is_real'):
        morning_peak = trends.get('peak_morning', 8)
        evening_peak = trends.get('peak_evening', 18)
        
        fig.add_vrect(
            x0=morning_peak-1, x1=morning_peak+1,
            fillcolor="rgba(234, 88, 12, 0.15)",
            layer="below", line_width=0,
            annotation_text=f"Pic {morning_peak}h",
            annotation_position="top left",
            annotation_font_size=9
        )
        
        fig.add_vrect(
            x0=evening_peak-1, x1=evening_peak+1,
            fillcolor="rgba(234, 88, 12, 0.15)",
            layer="below", line_width=0,
            annotation_text=f"Pic {evening_peak}h",
            annotation_position="top right",
            annotation_font_size=9
        )
        
        # Meilleur moment (ligne pointillée)
        best = trends.get('best_time', 2)
        fig.add_vline(
            x=best,
            line_dash="dash",
            line_color="#2D6A4F",
            line_width=2,
            annotation_text=f"Optimal {best}h",
            annotation_position="bottom",
            annotation_font_size=9
        )
    
    # Titre avec qualité des données
    title_text = f"📊 Tendances - {ville}"
    
    # Sous-titre selon qualité
    if trends.get('is_real'):
        fiabilite = trends.get('fiabilite', 0)
        data_points = trends.get('data_points', 0)
        subtitle = f"{data_points:,} points • {fiabilite:.0f}% couverture • {trends.get('jours_analysés', 7)}j"
        title_color = "#16a34a"
    else:
        subtitle = data_quality
        title_color = "#9CA3AF"
    
    fig.update_layout(
        title={
            'text': title_text,
            'font': {'size': 14, 'color': '#374151'}
        },
        xaxis_title="Heure",
        yaxis_title="Disponibilité (%)",
        height=250,
        margin=dict(l=40, r=20, t=60, b=30),
        showlegend=False,
        plot_bgcolor='rgba(0,0,0,0)',
        paper_bgcolor='rgba(0,0,0,0)',
        hovermode='x unified',
        annotations=[
            dict(
                xref="paper", yref="paper",
                x=0.5, y=1.15,
                text=subtitle,
                showarrow=False,
                font=dict(size=10, color=title_color),
                xanchor='center'
            )
        ]
    )
    
    # Ajouter métadonnées si disponibles
    if trends.get('metadata') and trends['metadata'].get('last_collection'):
        try:
            last_up = datetime.fromisoformat(trends['metadata']['last_collection']).strftime("%H:%M")
            fig.add_annotation(
                xref="paper", yref="paper",
                x=0.98, y=1.15,
                text=f"Màj {last_up}",
                showarrow=False,
                font=dict(size=9, color="#6B7280"),
                xanchor='right'
            )
        except:
            pass
    
    return dcc.Graph(figure=fig, config={'displayModeBar': False})

def build_collection_status_badge(ville: str):
    """
    Badge indiquant le statut de la collecte de données
    Intégration depuis mobilite_INTEGRATION_TRENDS.py
    """
    analyzer = get_trends_analyzer()
    if not analyzer:
        return html.Div(style={
            'padding': '6px 12px',
            'background': '#F3F4F6',
            'borderRadius': '6px',
            'fontSize': '0.75rem',
            'color': '#6B7280',
        }, children="📊 Module tendances non disponible")
    
    try:
        status = analyzer.get_collection_status(ville)
    except:
        status = {'status': 'unknown'}
    
    if status.get('status') == 'no_data':
        return html.Div(style={
            'padding': '6px 12px',
            'background': '#FEF3C7',
            'borderRadius': '6px',
            'fontSize': '0.75rem',
            'color': '#92400E',
            'border': '1px solid #FCD34D'
        }, children=[
            html.Span("⏳ ", style={'marginRight': '4px'}),
            "Collecte en cours... Données disponibles sous 48h"
        ])
    
    jours = status.get('jours_distincts', 0)
    heures = status.get('heures_distinctes', 0)
    total = status.get('total_snapshots', 0)
    
    if jours < 2:
        bg = '#DBEAFE'
        border = '#60A5FA'
        color = '#1E3A8A'
        icon = '🔄'
        text = f"En collecte : {jours}j • {heures}h • {total:,} pts"
    elif jours < 7:
        bg = '#D1FAE5'
        border = '#34D399'
        color = '#065F46'
        icon = '📊'
        text = f"Partiel : {jours}j • {heures}h • {total:,} pts"
    else:
        bg = '#D1FAE5'
        border = '#10B981'
        color = '#065F46'
        icon = '✅'
        text = f"Complet : {jours}j • {heures}h • {total:,} pts"
    
    return html.Div(style={
        'padding': '6px 12px',
        'background': bg,
        'borderRadius': '6px',
        'fontSize': '0.75rem',
        'color': color,
        'border': f'1px solid {border}'
    }, children=[
        html.Span(f"{icon} ", style={'marginRight': '4px'}),
        text
    ])

